{
  "name": "stonk-bot",
  "version": "2.3.4",
  "main": "index.js",
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "start": "vite-node ./src/index.ts",
    "lint:eslint": "eslint --report-unused-disable-directives --max-warnings 0 --cache --cache-strategy content .",
    "lint:oxlint": "oxlint --deny-warnings .",
    "lint:tsc": "tsc --strict --noEmit",
    "lint": "$npm_execpath run lint:oxlint && $npm_execpath run lint:tsc && $npm_execpath run lint:eslint",
    "format": "prettier --write ."
  },
  "engines": {
    "node": ">=24.x"
  },
  "dependencies": {
    "discord.js": "14.27.0",
    "dotenv": "17.4.2",
    "yahoo-finance2": "4.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.3.6",
    "@eslint/js": "10.0.1",
    "@types/node": "26.1.1",
    "@types/tough-cookie": "4.0.5",
    "@typescript-eslint/eslint-plugin": "8.64.0",
    "@typescript-eslint/parser": "8.64.0",
    "eslint": "10.7.0",
    "globals": "17.7.0",
    "npm-check-updates": "22.2.9",
    "oxlint": "1.74.0",
    "prettier": "3.9.5",
    "tslib": "2.8.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.64.0",
    "vite-node": "6.0.0"
  },
  "packageManager": "pnpm@11.13.0"
}
