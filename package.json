{
  "name": "stonk-bot",
  "version": "2.3.4",
  "main": "index.js",
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "start": "vite-node ./src/index.ts",
    "lint:eslint": "eslint --report-unused-disable-directives --max-warnings 0 .",
    "lint:tsc": "tsc --noEmit",
    "lint": "$npm_execpath run lint:eslint && $npm_execpath run lint:tsc",
    "format": "prettier --write ."
  },
  "engines": {
    "node": ">=24.x"
  },
  "dependencies": {
    "discord.js": "14.26.0",
    "dotenv": "17.3.1",
    "yahoo-finance2": "3.14.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.3.5",
    "@eslint/js": "10.0.1",
    "@types/node": "25.5.0",
    "@types/tough-cookie": "4.0.5",
    "@typescript-eslint/eslint-plugin": "8.58.0",
    "@typescript-eslint/parser": "8.58.0",
    "eslint": "10.1.0",
    "globals": "17.4.0",
    "npm-check-updates": "20.0.0",
    "prettier": "3.8.1",
    "tslib": "2.8.1",
    "typescript": "6.0.2",
    "typescript-eslint": "8.58.0",
    "vite-node": "6.0.0"
  },
  "packageManager": "pnpm@10.33.0"
}
